# Copiar aquí todas las funciones auxiliares y endpoints que ya teníamos...
# (get_etapa_text, get_origen_text, etc.)

def get_origen_text(origen: str) -> str:
    origenes = {
        'facebook': 'Facebook',
        'instagram': 'Instagram',
        'linkedin': 'LinkedIn',
        'twitter': 'Twitter',
        'web': 'Sitio Web',
        'referido': 'Referido',
        'llamada': 'Llamada',
        'email': 'Email',
        'google_ads': 'Google Ads',
        'evento': 'Evento',
        'tiktok': 'TikTok',
        'shopify': 'Shopify',
        'otro': 'Otro'
    }
    return origenes.get(origen, origen)

