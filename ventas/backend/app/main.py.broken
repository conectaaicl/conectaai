from fastapi import FastAPI, HTTPException
from fastapi.middleware.cors import CORSMiddleware
from fastapi.responses import StreamingResponse
from pydantic import BaseModel, Field, validator
from typing import Optional, Literal, List
from datetime import datetime, timedelta
from io import BytesIO
import openpyxl
from openpyxl.styles import Font, Alignment, PatternFill

app = FastAPI(title="Backend Ventas ConectaAI")

# CORS
app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

# =========================
# MODELOS PYDANTIC
# =========================

class DealBase(BaseModel):
    cliente: str = Field(..., min_length=1, max_length=200)
    monto: int = Field(..., gt=0)
    etapa: Literal['prospecto', 'calificado', 'propuesta', 'negociacion', 'ganado', 'perdido']
    origen: Optional[Literal['facebook', 'instagram', 'linkedin', 'twitter', 'web', 'referido', 'llamada', 'email', 'google_ads', 'evento', 'tiktok', 'shopify', 'otro']] = 'otro'
    fecha: str
    contacto: Optional[str] = None
    email: Optional[str] = None
    telefono: Optional[str] = None
    probabilidad: Optional[int] = Field(default=50, ge=0, le=100)
    
    @validator('email')
    def validate_email(cls, v):
        if v and '@' not in v:
            raise ValueError('Email inválido')
        return v

class DealCreate(DealBase):
    pass

class DealUpdate(DealBase):
    pass

class DealUpdateEtapa(BaseModel):
    etapa: Literal['prospecto', 'calificado', 'propuesta', 'negociacion', 'ganado', 'perdido']

class Deal(DealBase):
    id: int

class ActividadBase(BaseModel):
    tipo: Literal['nota', 'llamada', 'email', 'reunion', 'propuesta', 'negociacion', 'ganado', 'perdido', 'archivo']
    descripcion: str = Field(..., min_length=1, max_length=1000)
    fecha: Optional[str] = None
    usuario: Optional[str] = "Sistema"

class ActividadCreate(ActividadBase):
    deal_id: int

class Actividad(ActividadBase):
    id: int
    deal_id: int
    created_at: str

class MensajeBase(BaseModel):
    contenido: str = Field(..., min_length=1, max_length=5000)
    tipo: Literal['entrante', 'saliente'] = 'entrante'
    canal: Literal['whatsapp', 'instagram', 'facebook', 'web', 'email', 'sms', 'tiktok', 'shopify'] = 'whatsapp'

class MensajeCreate(MensajeBase):
    deal_id: int

class Mensaje(MensajeBase):
    id: int
    deal_id: int
    created_at: str
    leido: bool
    usuario: Optional[str] = None

class PlantillaBase(BaseModel):
    nombre: str = Field(..., min_length=1, max_length=100)
    contenido: str = Field(..., min_length=1, max_length=2000)
    categoria: Optional[str] = "general"
    activa: Optional[bool] = True

class PlantillaCreate(PlantillaBase):
    pass

class Plantilla(PlantillaBase):
    id: int

